@if (AuthorsViewModels is null || !AuthorsViewModels.Any())
{
    <div>Daten werden geladen...</div>
}
else
{
    <table class="table table-hover">
        <thead>
        <tr>
            <th>Photo</th>
            <th>Name</th>
            <th>Beschreibung</th>
            <th>Geburtsdatum</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
            @foreach (var author in AuthorsViewModels)
        {
            <tr>
                <td>
                    <DataImageUri MimeType="@author.PhotoMimeType"
                                  ImageContent="@author.Photo"
                                  alt="@author.Name"
                                  width="120">
                    </DataImageUri>
                </td>
                <td>@author.Name</td>
                <td>@author.Description</td>
                <td>@(author.BirthDate is not null ? author.BirthDate.Value.ToShortDateString() : "k.A.")</td>
                <td>
                    <!-- Aktion -->
                    <button type="button" class="btn btn-danger" @onclick="() => ShowConfirmationModal(author)"><i class="bi bi-trash"></i></button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}