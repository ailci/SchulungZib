@if (QotdVm is null)
{
    <div>Quote Of the day wird geladen...</div>
}
else
{
    <div class="container">
        <div class="text-center">
            <div class="p-2 rounded-3">
                <h5 class="display-6 py-3">@Title</h5>
                <p class="text-center">
                    <!-- 1. Variante -->
                  @*   @if (!string.IsNullOrEmpty(QotdVm.AuthorPhotoMimeType) && QotdVm.AuthorPhoto is not null)
                    {
                        <img width="150" src="data:@QotdVm.AuthorPhotoMimeType;base64,@Convert.ToBase64String(QotdVm.AuthorPhoto)" alt="@QotdVm.AuthorName" />
                    }
                    else //Kein Bild
                    {
                        <img width="150" src="noimg.jpg" alt="@QotdVm.AuthorName" />
                    } *@

                    <!-- 2.Variante als Component -->
                    <DataImageUri MimeType="@QotdVm.AuthorPhotoMimeType"
                                  ImageContent="@QotdVm.AuthorPhoto" alt="@QotdVm.AuthorName" width="100">
                    </DataImageUri>
                </p>
                <blockquote class="text-center">
                    <p class="lead fw-bold" id="quote">@QotdVm.QuoteText</p>
                    <cite>
                        <span>@QotdVm.AuthorName - @QotdVm.AuthorDescription</span>
                        <br />
                        <span>@(QotdVm.AuthorBirthDate is not null ? QotdVm.AuthorBirthDate.Value.ToShortDateString() : "")</span>
                    </cite>
                </blockquote>
            </div>
        </div>
        <div class="alert alert-dark overflow-hidden">
            @LogOfQotd
        </div>
    </div>
}

@code {

    [Parameter, EditorRequired]
    public string? Title { get; set; }

    [Parameter, EditorRequired]
    public QuoteOfTheDayViewModel? QotdVm { get; set; }

    [Parameter]
    public RenderFragment? LogOfQotd { get; set; }
}
